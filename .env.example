# Database Configuration
POSTGRES_USER=marketing_agent_user
POSTGRES_PASSWORD=password
POSTGRES_DB=marketing_agent

# Security (Leave empty for Dev Mode, or set a secure string for Production)
MARKETING_AGENT_API_KEY=my_secure_api_key_123

# WhatsApp Integration (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=placeholder_token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BASE_URL=https://graph.facebook.com

# Groq Integration (LLaMA 3 70B)
GROQ_API_KEY=your_groq_api_key_here

# AWS S3 Storage Integration (Optional, falls back to local disk storage if blank)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

